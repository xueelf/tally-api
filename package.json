{
  "name": "tally-api",
  "type": "module",
  "license": "MIT",
  "author": "Yuki <admin@yuki.sh>",
  "scripts": {
    "dev": "bun run docs:build && bun run types && wrangler pages dev ./dist",
    "types": "wrangler types ./types/worker-configuration.d.ts",
    "format": "prettier **/*.ts --write",
    "lint": "eslint **/*.ts",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.58.2",
    "vitepress": "^1.6.4",
    "wrangler": "^4.83.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "devEngines": {
    "runtime": {
      "name": "bun",
      "onFail": "error"
    },
    "packageManager": {
      "name": "bun",
      "onFail": "error"
    }
  },
  "private": true
}
